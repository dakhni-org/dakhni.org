      "type": "html",
      "html": "<style>\n/* ══════════ Silsila tree — scoped st- namespace ══════════ */\n.st-app{margin:1rem 0 0}\n.st-toolbar{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:.8rem;margin-bottom:.9rem}\n.st-btn{font-family:'Inter',sans-serif;font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-soft);background:#FDFBF5;border:1px solid var(--rule);border-radius:99px;padding:.5rem 1rem;cursor:pointer;transition:color .2s,border-color .2s,background .2s}\n.st-btn:hover{color:var(--gold-deep);border-color:var(--gold)}\n.st-btn-gold{color:var(--gold-deep);border:1.5px dashed var(--gold);background:#FBF3DE}\n.st-btn-gold:hover{background:#F6E9C9}\n.st-tools{display:inline-flex;gap:.4rem}\n.st-tools .st-btn{padding:.5rem .85rem}\n.st-legend{display:flex;flex-wrap:wrap;gap:.45rem .6rem;margin-bottom:1rem}\n.st-lg{display:inline-flex;align-items:center;gap:.4rem;font-family:'Inter',sans-serif;font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-faint);border:1px solid var(--rule-soft);border-radius:99px;padding:.3rem .7rem;background:#FDFBF5}\n.st-dot{width:10px;height:10px;border-radius:50%;flex:none}\n.st-lg-saint .st-dot{background:linear-gradient(180deg,#FBF3DE,#E8CE8F);border:1.5px solid var(--gold-deep)}\n.st-lg-founder .st-dot{background:var(--ink-soft)}\n.st-lg-dash .st-dot{background:transparent;border:1.5px dashed var(--gold-deep)}\n.st-viewport{position:relative;overflow:auto;background:#FCFAF4;border:1px solid var(--rule);border-radius:14px;box-shadow:inset 0 1px 8px rgba(26,24,20,.04);cursor:grab;-webkit-overflow-scrolling:touch}\n.st-viewport.st-grabbing{cursor:grabbing}\n.st-canvas{position:relative;margin:0 auto}\n.st-tree{position:absolute;top:0;left:0;transform-origin:0 0;padding:2.2rem 2rem 2.6rem;width:max-content}\n/* ── org-chart connector geometry ── */\n.st-tree ul{display:flex;justify-content:center;list-style:none;margin:0;padding:1.7rem 0 0;position:relative}\n.st-tree li{display:flex;flex-direction:column;align-items:center;position:relative;padding:1.7rem .55rem 0;--lc:rgba(107,71,16,.32)}\n.st-tree li::before,.st-tree li::after{content:'';position:absolute;top:0;right:50%;width:50%;height:1.7rem;border-top:1.5px solid var(--lc)}\n.st-tree li::after{right:auto;left:50%;border-left:1.5px solid var(--lc)}\n.st-tree li:only-child::before,.st-tree li:only-child::after{display:none}\n.st-tree li:only-child{padding-top:0}\n.st-tree li:first-child::before,.st-tree li:last-child::after{border-top:none}\n.st-tree li:last-child::before{border-right:1.5px solid var(--lc);border-radius:0 8px 0 0}\n.st-tree li:first-child::after{border-radius:8px 0 0 0}\n.st-tree ul ul::before{content:'';position:absolute;top:0;left:50%;width:0;height:1.7rem;border-left:1.5px solid var(--lc)}\n.st-tree>ul{padding-top:0}\n.st-tree>ul>li{padding-top:0}\n.st-tree>ul>li::before,.st-tree>ul>li::after{display:none}\n/* dashed connectors = documented but unnamed links, or family descent */\n.st-tree li.st-dash::before,.st-tree li.st-dash::after{border-top-style:dashed;border-left-style:dashed}\n.st-tree li.st-dash:last-child::before{border-right-style:dashed}\n.st-tree ul.st-dashkids::before{border-left-style:dashed}\n/* branch colours */\n.st-b-qadiri{--oc:#7B3030;--lc:rgba(123,48,48,.4)}\n.st-b-suhrawardi{--oc:#2E5A66;--lc:rgba(46,90,102,.4)}\n.st-b-chishti{--oc:#3F5D3B;--lc:rgba(63,93,59,.42)}\n.st-b-hamadani{--oc:#46617A;--lc:rgba(70,97,122,.4)}\n.st-b-naqshbandi{--oc:#5C3A6B;--lc:rgba(92,58,107,.4)}\n.st-b-root{--oc:var(--gold-deep);--lc:rgba(160,112,32,.45)}\n/* ── node cards ── */\n.st-cardwrap{position:relative;z-index:1}\n.st-node{display:block;position:relative;background:#FDFBF5;border:1px solid rgba(26,24,20,.14);border-top:3px solid var(--oc,#8B8472);border-radius:9px;min-width:158px;max-width:200px;padding:.85rem .9rem .8rem;text-align:center;box-shadow:0 1px 3px rgba(26,24,20,.06);color:inherit;text-decoration:none}\n.st-chip{display:inline-block;font-family:'Inter',sans-serif;font-size:.52rem;font-weight:500;letter-spacing:.15em;text-transform:uppercase;color:#FAF7EF;background:var(--oc,#8B8472);padding:.16rem .55rem;border-radius:99px;margin-bottom:.5rem}\n.st-name{font-family:'Cormorant Garamond',serif;font-size:1.04rem;font-weight:600;line-height:1.22;color:var(--ink);margin:0}\n.st-sub{font-family:'EB Garamond',serif;font-style:italic;font-size:.78rem;color:var(--ink-faint);margin:.25rem 0 0}\n.st-role{font-family:'Inter',sans-serif;font-size:.58rem;letter-spacing:.03em;line-height:1.5;color:var(--ink-soft);margin:.45rem 0 0}\n.st-urdu{font-family:'Lateef',serif;font-size:1.15rem;line-height:1.1;color:var(--oc);margin:0 0 .1rem}\n/* masters in the chain */\n.st-link .st-chip{background:transparent;color:var(--oc);border:1px solid var(--oc)}\n/* lineage nodes */\n.st-line{background:#F7F4EA;border-style:dashed}\n.st-line .st-chip{background:transparent;color:var(--oc);border:1px dashed var(--oc)}\n/* founders — filled in the order colour */\n.st-founder{background:var(--oc);border-color:var(--oc)}\n.st-founder .st-chip{background:rgba(250,247,239,.16);color:#FAF7EF}\n.st-founder .st-name{color:#FAF7EF}\n.st-founder .st-sub{color:rgba(250,247,239,.72)}\n.st-founder .st-role{color:rgba(250,247,239,.8)}\n.st-founder .st-urdu{color:rgba(250,247,239,.92)}\n/* the seven saints of this archive — gold */\n.st-saint{background:linear-gradient(180deg,#FBF3DE,#F3E5C0);border:1.5px solid var(--gold);border-top:3.5px solid var(--gold-deep);box-shadow:0 3px 12px rgba(160,112,32,.18)}\n.st-saint .st-name{color:var(--gold-deep);font-size:1.1rem}\n.st-saint .st-chip{background:var(--gold-deep)}\n.st-saint .st-role{color:#5c4a22}\n.st-star{position:absolute;top:-10px;left:50%;transform:translateX(-50%);width:20px;height:20px;line-height:20px;border-radius:50%;background:var(--gold-deep);color:#F6E9C9;font-size:.62rem;text-align:center}\n.st-goto{display:inline-block;margin-top:.5rem;font-family:'Inter',sans-serif;font-size:.54rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold-deep);border-bottom:1px solid var(--gold);padding-bottom:1px}\na.st-node{transition:transform .2s,box-shadow .2s}\na.st-node:hover{transform:translateY(-3px);box-shadow:0 8px 20px rgba(160,112,32,.25)}\n/* Prophet ﷺ */\n.st-prophet{background:var(--ink);border-color:var(--ink);border-top:3.5px solid var(--gold);min-width:230px;padding:1.05rem 1.2rem 1rem}\n.st-prophet .st-urdu{font-size:1.7rem;color:var(--gold-soft)}\n.st-prophet .st-name{color:var(--gold-soft);font-size:1.18rem}\n.st-prophet .st-sub{color:rgba(201,169,104,.75)}\n.st-prophet .st-role{color:rgba(250,247,239,.7)}\n/* Companions */\n.st-comp{background:var(--cream)}\n.st-comp .st-chip{background:transparent;color:var(--gold-deep);border:1px solid var(--gold)}\n.st-comp .st-name{color:var(--gold-deep)}\n/* unnamed generations */\n.st-gap{min-width:0;max-width:150px;background:transparent;border:1.5px dashed rgba(107,71,16,.45);border-radius:11px;padding:.45rem .7rem .5rem;box-shadow:none}\n.st-dots{display:block;font-size:.85rem;letter-spacing:.35em;color:var(--gold-deep);line-height:1}\n.st-glabel{display:block;font-family:'Inter',sans-serif;font-size:.5rem;letter-spacing:.09em;text-transform:uppercase;color:var(--ink-faint);line-height:1.5;margin-top:.28rem}\n/* condensed-origin capsule */\n.st-origin{display:flex;align-items:center;gap:.8rem;background:#FBF3DE;border:1.5px dashed var(--gold);border-radius:99px;min-width:0;max-width:none;padding:.7rem 1.6rem;cursor:pointer;box-shadow:none;text-align:left}\n.st-origin:hover{background:#F6E9C9}\n.st-origin .st-up{font-size:1rem;color:var(--gold-deep)}\n.st-origin .st-name{font-size:.98rem;color:var(--gold-deep);white-space:nowrap}\n.st-origin .st-sub{margin:0;white-space:nowrap}\n/* fold / unfold chip */\n.st-tg{position:absolute;bottom:-11px;left:50%;transform:translateX(-50%);z-index:3;min-width:22px;height:22px;padding:0 .4rem;border-radius:99px;border:1.5px solid var(--oc,#8B8472);background:#FDFBF5;color:var(--oc,#8B8472);font-family:'Inter',sans-serif;font-size:.62rem;line-height:19px;cursor:pointer}\n.st-tg:hover{background:var(--oc);color:#FAF7EF}\nli.st-closed>ul{display:none}\n.st-hint{font-family:'Inter',sans-serif;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-faint);text-align:center;margin-top:.8rem}\n@media(max-width:640px){\n  .st-toolbar{justify-content:center}\n  .st-tree{padding:1.4rem 1rem 1.8rem}\n}\n</style>\n\n<div class=\"pillars-strip\">\n  <span class=\"pillars-strip-label\">The Shajara</span>\n  <a href=\"#chains\">The Chains</a><span class=\"pillars-strip-sep\">◆</span><a href=\"#tree\">The Tree</a><span class=\"pillars-strip-sep\">◆</span><a href=\"#notes\">Reading the Tree</a>\n</div>\n\n<section class=\"section-wrap narrow\" id=\"chains\">\n  <span class=\"sec-label\">I · The Chains</span>\n  <h2 class=\"sec-title\">Seven saints, one <em style=\"color:var(--gold-deep);font-style:italic;\">tree</em></h2>\n  <p class=\"section-intro\">Every saint recorded in this archive stood inside a chain of masters — and every chain ascends to the same root.</p>\n  <div class=\"prose\">\n    <p>A Sufi's authority is documentary. Each of the seven saints whose lives this archive records held a formal place in a <em>silsila</em> — a chain of teachers in which each master licensed his successor by <em>khilafat</em>, link by link, back through the founder of the order and the generations before him to the Companions of the Prophet ﷺ and to the Prophet ﷺ himself. To ask \"who was this saint's master?\" is therefore always answerable, and the answers connect: Burhanuddin Gharib and Bandanawaz Gisudaraz meet two links apart in the hospice of Nizamuddin Awliya; Shah Raju Qattal and the Yousufain brothers stand on one Qadiri stem; and all of the chains, followed far enough upward, converge.</p>\n    <p>The chart below assembles those chains — exactly as each saint's own record on this site documents them — into a single tree, or <em>shajara</em>. The <strong style=\"color:var(--gold-deep);\">gold cards</strong> are the seven saints of this archive; selecting one opens his full record. The filled, coloured cards are the founders of the four classical silsilas of the Deccan — Chishti, Qadiri, Suhrawardi and Naqshbandi — with a fifth, slate-coloured line for the Hamadani family descent of Hussain Shah Wali. Dashed connectors mark links the records document but do not name, or descent by family rather than formal khilafat.</p>\n  </div>\n</section>\n\n<hr class=\"h-rule\"/>\n\n<section class=\"section-wrap\" id=\"tree\">\n  <span class=\"sec-label\">II · The Tree</span>\n  <h2 class=\"sec-title\">From the Prophet ﷺ to the <em style=\"color:var(--gold-deep);font-style:italic;\">Deccan</em></h2>\n  <p class=\"section-intro\">The tree opens at the founders of the orders. Use the bar at the top of the chart — or the button below — to reveal the earlier generations, up to the Companions and the Prophet ﷺ.</p>\n\n  <div class=\"st-app\">\n    <div class=\"st-toolbar\">\n      <button type=\"button\" id=\"st-up\" class=\"st-btn st-btn-gold\" aria-expanded=\"false\">⌃ &nbsp;Show the chain to the Prophet ﷺ</button>\n      <span class=\"st-tools\">\n        <button type=\"button\" id=\"st-zout\" class=\"st-btn\" aria-label=\"Zoom out\">−</button>\n        <button type=\"button\" id=\"st-zin\" class=\"st-btn\" aria-label=\"Zoom in\">+</button>\n        <button type=\"button\" id=\"st-fit\" class=\"st-btn\">Fit</button>\n      </span>\n    </div>\n    <div class=\"st-legend\" aria-label=\"Legend\">\n      <span class=\"st-lg st-lg-saint\"><span class=\"st-dot\"></span>✦ Saint of this archive — opens his record</span>\n      <span class=\"st-lg st-lg-founder\"><span class=\"st-dot\"></span>Founder of a silsila</span>\n      <span class=\"st-lg st-lg-dash\"><span class=\"st-dot\"></span>Documented, unnamed links · family descent</span>\n      <span class=\"st-lg\"><span class=\"st-dot\" style=\"background:#7B3030\"></span>Qadiri</span>\n      <span class=\"st-lg\"><span class=\"st-dot\" style=\"background:#2E5A66\"></span>Suhrawardi</span>\n      <span class=\"st-lg\"><span class=\"st-dot\" style=\"background:#3F5D3B\"></span>Chishti</span>\n      <span class=\"st-lg\"><span class=\"st-dot\" style=\"background:#46617A\"></span>Hamadani line</span>\n      <span class=\"st-lg\"><span class=\"st-dot\" style=\"background:#5C3A6B\"></span>Naqshbandi</span>\n    </div>\n    <div class=\"st-viewport\" id=\"st-viewport\">\n      <div class=\"st-canvas\" id=\"st-canvas\">\n        <div class=\"st-tree\" id=\"st-tree\"></div>\n      </div>\n    </div>\n    <p class=\"st-hint\">Drag or scroll sideways to travel across the tree · use the circle beneath a card to fold or unfold its successors</p>\n  </div>\n\n  <noscript>\n    <div class=\"prose\" style=\"margin-top:2rem;\">\n      <p><strong>The chains, in brief</strong> (the interactive tree needs JavaScript):</p>\n      <p><em>Chishti</em> — Khwaja Mu'inuddin Chishti of Ajmer → Qutbuddin Bakhtiyar Kaki → Baba Farid of Pakpattan → Nizamuddin Awliya → <a href=\"/sufism/burhanuddin/\">Burhanuddin Gharib</a> of Khuldabad; and Nizamuddin Awliya → Nasir al-Din Chiragh-i-Delhi → <a href=\"/sufism/bandanawaz/\">Bandanawaz Gisudaraz</a> of Gulbarga.</p>\n      <p><em>Qadiri</em> — Shaykh 'Abd al-Qadir Jilani of Baghdad → (documented chain) → Sayyid Yusuf al-Husayni of Bidar → <a href=\"/sufism/shah-raju/\">Shah Raju Qattal</a> of Hyderabad → his descendants, the <a href=\"/sufism/yousufain/\">Yousufain brothers</a> and the Mahbub Subhani line.</p>\n      <p><em>Suhrawardi</em> — Shaykh Shihab al-Din 'Umar al-Suhrawardi of Baghdad → Baha al-Din Zakariya of Multan → (documented chain) → <a href=\"/sufism/sharfuddin/\">Baba Sharfuddin</a> of Pahadi Sharif.</p>\n      <p><em>Hamadani line</em> — the family of Sayyid 'Ali al-Hamadhani of Kashmir → <a href=\"/sufism/hussain-shah-wali/\">Hussain Shah Wali</a> of Hyderabad.</p>\n      <p><em>Naqshbandi</em> — Khwaja Baha al-Din Naqshband of Bukhara → (brought south by Mughal-era scholars) → the Naqshbandi-Qadiri line of Hyderabad → <a href=\"/sufism/shah-khamosh/\">Shah Khamosh</a>.</p>\n    </div>\n  </noscript>\n</section>\n\n<section class=\"note-card\" id=\"notes\" aria-label=\"A note on reading the tree\">\n  <span class=\"note-card-label\">Reading the Tree</span>\n  <p class=\"note-card-body\">This shajara is drawn strictly from the seven saint records of this archive and the Sufism index page; it introduces no names or dates beyond them. A solid line is a master-to-disciple (or master-to-khalifa) relation named in the records — comparable, as the index page notes, to a hadith chain of transmission (<em>isnad</em>). A dashed line marks either links the records document but do not name — as between 'Abd al-Qadir Jilani and Sayyid Yusuf al-Husayni of Bidar, or in the Multan chain above Baba Sharfuddin — or descent by family rather than formal khilafat, as with the Yousufain brothers from Shah Raju Qattal and Hussain Shah Wali from the family of 'Ali al-Hamadhani. Shah Khamosh belonged to the combined Naqshbandi-Qadiri silsila characteristic of early Asaf Jahi Hyderabad; the tree places him on the Naqshbandi stem, which by the classical reckoning ascends through Abu Bakr al-Siddiq, while the other chains ascend through 'Ali ibn Abi Talib. The generations between the Companions and the founders of the orders are shown condensed.</p>\n</section>\n\n<script>\n(function(){\n  \"use strict\";\n\n  /* ── the tree, drawn from the saint records of this site ── */\n\n  var yousuf = {k:\"saint\", b:\"qadiri\", dash:true, chip:\"Qadiri · Descendant\", name:\"Shah Yousuf-uddin Husayni\", sub:\"Nampally, Hyderabad · c. 1668–1741\", role:\"The elder of the Yousufain — teacher of hadith at Hyderabad\", url:\"/sufism/yousufain/\"};\n  var sharif = {k:\"saint\", b:\"qadiri\", dash:true, chip:\"Qadiri · Descendant\", name:\"Shah Sharif-uddin Husayni\", sub:\"Nampally, Hyderabad · 18th c.\", role:\"The younger of the Yousufain — principal khalifa of the family\", url:\"/sufism/yousufain/\"};\n  var mahbub = {k:\"line\", b:\"qadiri\", dash:true, chip:\"Lineage\", name:\"The Mahbub Subhani line\", sub:\"Later Asaf Jahi period\", role:\"Qadiri family line descended from Shah Raju\"};\n  var shahraju = {k:\"saint\", b:\"qadiri\", chip:\"Qadiri\", name:\"Shah Raju Qattal Qadiri\", sub:\"Bidar → Misri Gunj, Hyderabad · d. c. 1632\", role:\"Founder of the Qadiri silsila at Hyderabad\", url:\"/sufism/shah-raju/\", kids:[yousuf, sharif, mahbub]};\n  var yusufBidar = {k:\"link\", b:\"qadiri\", dash:true, chip:\"In the chain\", name:\"Sayyid Yusuf al-Husayni\", sub:\"Bidar\", role:\"Named link in the silsila records of the Hyderabad Qadiri family\", kids:[shahraju]};\n  var gapQ = {k:\"gap\", b:\"qadiri\", dash:true, name:\"Unnamed links of the documented chain\", kids:[yusufBidar]};\n  var jilani = {k:\"founder\", b:\"qadiri\", dash:true, chip:\"Qadiriyya · Founder\", urdu:\"قادریہ\", name:\"Shaykh 'Abd al-Qadir Jilani\", sub:\"Baghdad · d. 1166\", role:\"Master of the Qadiri silsila\", kids:[gapQ]};\n\n  var sharfuddin = {k:\"saint\", b:\"suhrawardi\", dash:true, chip:\"Suhrawardi\", name:\"Baba Sharfuddin\", sub:\"Pahadi Sharif, Hyderabad · late 15th c.\", role:\"The Suhrawardi saint of the hill — Pahadi Wale Baba\", url:\"/sufism/sharfuddin/\"};\n  var gapS = {k:\"gap\", b:\"suhrawardi\", dash:true, name:\"Unnamed masters of the Multan chain\", kids:[sharfuddin]};\n  var zakariya = {k:\"link\", b:\"suhrawardi\", chip:\"Khalifa\", name:\"Baha al-Din Zakariya\", sub:\"Multan\", role:\"The great khalifa who carried the order into the subcontinent\", kids:[gapS]};\n  var suhrawardi = {k:\"founder\", b:\"suhrawardi\", dash:true, chip:\"Suhrawardiyya · Founder\", urdu:\"سہروردیہ\", name:\"Shihab al-Din 'Umar al-Suhrawardi\", sub:\"Baghdad · d. 1234\", role:\"Master of the Suhrawardi silsila\", kids:[zakariya]};\n\n  var zayn = {k:\"link\", b:\"chishti\", chip:\"Khalifa · Successor\", name:\"Zayn al-Din Shirazi\", sub:\"Khuldabad · d. 1369\", role:\"Successor at the Khuldabad hospice\"};\n  var rukn = {k:\"link\", b:\"chishti\", chip:\"Disciple\", name:\"Rukn al-Din Dabir al-Mulk\", sub:\"Khuldabad\", role:\"Compiler of the Nafa'is al-Anfas\"};\n  var burhanuddin = {k:\"saint\", b:\"chishti\", chip:\"Chishti\", name:\"Burhanuddin Gharib\", sub:\"Hansi → Khuldabad · d. 1337\", role:\"First Chishti shaykh of the Deccan — founder of the Khuldabad hospice\", url:\"/sufism/burhanuddin/\", kids:[zayn, rukn]};\n  var akbar = {k:\"link\", b:\"chishti\", chip:\"Disciple\", name:\"Sayyid Muhammad Akbar Husayni\", sub:\"Gulbarga\", role:\"Compiler of the Javami' al-Kalim\"};\n  var bandanawaz = {k:\"saint\", b:\"chishti\", chip:\"Chishti\", name:\"Bandanawaz Gisudaraz\", sub:\"Delhi → Gulbarga · 1321–1422\", role:\"The most learned Sufi of the medieval Deccan\", url:\"/sufism/bandanawaz/\", kids:[akbar]};\n  var chiragh = {k:\"link\", b:\"chishti\", chip:\"Khalifa\", name:\"Nasir al-Din Chiragh-i-Delhi\", sub:\"Delhi · d. 1356\", role:\"Chief successor of Nizamuddin Awliya — the last great Chishti of the north\", kids:[bandanawaz]};\n  var nizamuddin = {k:\"link\", b:\"chishti\", chip:\"Khalifa\", name:\"Khwaja Nizamuddin Awliya\", sub:\"Delhi · d. 1325\", role:\"The great Chishti master of the Delhi Sultanate — his khalifas carried the order to the Deccan\", kids:[burhanuddin, chiragh]};\n  var farid = {k:\"link\", b:\"chishti\", chip:\"Khalifa\", name:\"Baba Farid\", sub:\"Pakpattan\", role:\"Master of Nizamuddin Awliya\", kids:[nizamuddin]};\n  var kaki = {k:\"link\", b:\"chishti\", chip:\"Khalifa\", name:\"Qutbuddin Bakhtiyar Kaki\", sub:\"Delhi\", role:\"Successor of Mu'inuddin in the Indian Chishti chain\", kids:[farid]};\n  var moinuddin = {k:\"founder\", b:\"chishti\", dash:true, chip:\"Chishtiyya · Founder\", urdu:\"چشتیہ\", name:\"Khwaja Mu'inuddin Chishti\", sub:\"Ajmer · d. 1236\", role:\"Master of the Chishti silsila in India\", kids:[kaki]};\n\n  var hussain = {k:\"saint\", b:\"hamadani\", dash:true, chip:\"Hamadani line\", name:\"Hussain Shah Wali\", sub:\"Golconda → Hyderabad · d. 1599\", role:\"Scholar-engineer of the Hussain Sagar (1562)\", url:\"/sufism/hussain-shah-wali/\"};\n  var gapH = {k:\"gap\", b:\"hamadani\", dash:true, name:\"Family descent · generations\", kids:[hussain]};\n  var hamadani = {k:\"founder\", b:\"hamadani\", dash:true, chip:\"Hamadani line\", name:\"Sayyid 'Ali al-Hamadhani\", sub:\"Kashmir\", role:\"The Sufi master whose family line reached the Deccan\", kids:[gapH]};\n\n  var khamosh = {k:\"saint\", b:\"naqshbandi\", dash:true, chip:\"Naqshbandi-Qadiri\", name:\"Shah Khamosh\", sub:\"Old City, Hyderabad · d. 1740\", role:\"The silent saint — counsellor to Asaf Jah I\", url:\"/sufism/shah-khamosh/\"};\n  var nqline = {k:\"line\", b:\"naqshbandi\", dash:true, chip:\"Combined line\", name:\"The Naqshbandi-Qadiri line of Hyderabad\", sub:\"17th–18th c.\", role:\"Established through Khwaja Habibullah Naqshbandi and others — joined with the Qadiri chain\", kids:[khamosh]};\n  var gapN = {k:\"gap\", b:\"naqshbandi\", dash:true, name:\"Carried to India by Mughal-era scholars\", kids:[nqline]};\n  var naqshband = {k:\"founder\", b:\"naqshbandi\", dash:true, chip:\"Naqshbandiyya · Founder\", urdu:\"نقشبندیہ\", name:\"Khwaja Baha al-Din Naqshband\", sub:\"Bukhara · d. 1389\", role:\"Master of the Naqshbandi silsila\", kids:[gapN]};\n\n  var branches = [jilani, suhrawardi, moinuddin, hamadani, naqshband];\n\n  var origin = {k:\"origin\", b:\"root\", name:\"The chains continue upward\", sub:\"through the Companions to the Prophet ﷺ — show the earlier generations\", kids:branches};\n\n  var ali = {k:\"comp\", b:\"root\", chip:\"Companion\", name:\"'Ali ibn Abi Talib\", role:\"Fountainhead of the Chishti, Qadiri, Suhrawardi and Hamadani chains\",\n    kids:[\n      {k:\"gap\", b:\"qadiri\", dash:true, name:\"Generations of the chain\", kids:[jilani]},\n      {k:\"gap\", b:\"suhrawardi\", dash:true, name:\"Generations of the chain\", kids:[suhrawardi]},\n      {k:\"gap\", b:\"chishti\", dash:true, name:\"Generations of the chain\", kids:[moinuddin]},\n      {k:\"gap\", b:\"hamadani\", dash:true, name:\"Generations of the chain\", kids:[hamadani]}\n    ]};\n  var abubakr = {k:\"comp\", b:\"root\", chip:\"Companion\", name:\"Abu Bakr al-Siddiq\", role:\"Fountainhead of the Naqshbandi chain\",\n    kids:[ {k:\"gap\", b:\"naqshbandi\", dash:true, name:\"Generations of the chain\", kids:[naqshband]} ]};\n  var prophet = {k:\"prophet\", b:\"root\", urdu:\"مُحَمَّد رَسُولُ الله ﷺ\", name:\"The Prophet Muhammad ﷺ\", sub:\"Madina · d. 632 CE\", role:\"Every silsila of Tasawwuf begins its chain with him\", kids:[ali, abubakr]};\n\n  /* ── rendering ── */\n\n  var treeEl = document.getElementById(\"st-tree\");\n  var canvas = document.getElementById(\"st-canvas\");\n  var viewport = document.getElementById(\"st-viewport\");\n  var upBtn = document.getElementById(\"st-up\");\n  var full = false;\n  var z = 1;\n\n  function cardHtml(n){\n    var h = \"\";\n    if(n.k === \"gap\"){\n      h = \"<span class='st-dots'>· · ·</span><span class='st-glabel'>\" + n.name + \"</span>\";\n      return \"<div class='st-node st-gap'>\" + h + \"</div>\";\n    }\n    if(n.k === \"origin\"){\n      h = \"<span class='st-up'>⌃</span><span><h4 class='st-name'>\" + n.name + \"</h4><p class='st-sub'>\" + n.sub + \"</p></span>\";\n      return \"<button type='button' class='st-node st-origin' id='st-origin-node'>\" + h + \"</button>\";\n    }\n    if(n.k === \"saint\"){ h += \"<span class='st-star'>✦</span>\"; }\n    if(n.chip){ h += \"<span class='st-chip'>\" + n.chip + \"</span>\"; }\n    if(n.urdu){ h += \"<div class='st-urdu'>\" + n.urdu + \"</div>\"; }\n    h += \"<h4 class='st-name'>\" + n.name + \"</h4>\";\n    if(n.sub){ h += \"<p class='st-sub'>\" + n.sub + \"</p>\"; }\n    if(n.role){ h += \"<p class='st-role'>\" + n.role + \"</p>\"; }\n    if(n.url){ h += \"<span class='st-goto'>Read the record</span>\"; }\n    var cls = \"st-node st-\" + n.k;\n    if(n.url){ return \"<a class='\" + cls + \"' href='\" + n.url + \"'>\" + h + \"</a>\"; }\n    return \"<div class='\" + cls + \"'>\" + h + \"</div>\";\n  }\n\n  function countBelow(n){\n    var c = 0;\n    (n.kids || []).forEach(function(kid){\n      if(kid.k !== \"gap\"){ c += 1; }\n      c += countBelow(kid);\n    });\n    return c;\n  }\n\n  function liHtml(n){\n    var cls = \"st-b-\" + (n.b || \"root\") + (n.dash ? \" st-dash\" : \"\");\n    var h = \"<li class='\" + cls + \"'><div class='st-cardwrap'>\" + cardHtml(n);\n    var kids = n.kids || [];\n    if(kids.length && n.k !== \"gap\" && n.k !== \"origin\" && n.k !== \"prophet\" && n.k !== \"comp\"){\n      h += \"<button type='button' class='st-tg' data-count='\" + countBelow(n) + \"' aria-expanded='true' aria-label='Fold or unfold successors'>−</button>\";\n    }\n    h += \"</div>\";\n    if(kids.length){\n      var allDash = kids.every(function(kid){ return kid.dash; });\n      h += \"<ul\" + (allDash ? \" class='st-dashkids'\" : \"\") + \">\" + kids.map(liHtml).join(\"\") + \"</ul>\";\n    }\n    return h + \"</li>\";\n  }\n\n  function layout(){\n    treeEl.style.transform = \"scale(\" + z + \")\";\n    canvas.style.width = Math.round(treeEl.offsetWidth * z) + \"px\";\n    canvas.style.height = Math.round(treeEl.offsetHeight * z) + \"px\";\n  }\n\n  function centerView(){\n    viewport.scrollLeft = Math.max(0, (canvas.offsetWidth - viewport.clientWidth) / 2);\n    viewport.scrollTop = 0;\n  }\n\n  function fit(){\n    var w = treeEl.offsetWidth;\n    if(w > 0){\n      z = Math.min(1, Math.max(0.45, (viewport.clientWidth - 16) / w));\n      layout();\n      centerView();\n    }\n  }\n\n  function setZoom(nz){\n    var cx = (viewport.scrollLeft + viewport.clientWidth / 2) / Math.max(1, canvas.offsetWidth);\n    var cy = (viewport.scrollTop + viewport.clientHeight / 2) / Math.max(1, canvas.offsetHeight);\n    z = nz;\n    layout();\n    viewport.scrollLeft = cx * canvas.offsetWidth - viewport.clientWidth / 2;\n    viewport.scrollTop = cy * canvas.offsetHeight - viewport.clientHeight / 2;\n  }\n\n  function render(){\n    var root = full ? prophet : origin;\n    treeEl.innerHTML = \"<ul>\" + liHtml(root) + \"</ul>\";\n    upBtn.innerHTML = full ? \"⌄ &nbsp;Condense the earlier generations\" : \"⌃ &nbsp;Show the chain to the Prophet ﷺ\";\n    upBtn.setAttribute(\"aria-expanded\", full ? \"true\" : \"false\");\n    fit();\n  }\n\n  treeEl.addEventListener(\"click\", function(e){\n    var tg = e.target.closest(\".st-tg\");\n    if(tg){\n      var li = tg.closest(\"li\");\n      var closed = li.classList.toggle(\"st-closed\");\n      tg.textContent = closed ? \"+\" + tg.getAttribute(\"data-count\") : \"−\";\n      tg.setAttribute(\"aria-expanded\", closed ? \"false\" : \"true\");\n      layout();\n      return;\n    }\n    if(e.target.closest(\"#st-origin-node\")){\n      full = true;\n      render();\n    }\n  });\n\n  upBtn.addEventListener(\"click\", function(){ full = !full; render(); });\n  document.getElementById(\"st-zin\").addEventListener(\"click\", function(){ setZoom(Math.min(1.3, z + 0.12)); });\n  document.getElementById(\"st-zout\").addEventListener(\"click\", function(){ setZoom(Math.max(0.4, z - 0.12)); });\n  document.getElementById(\"st-fit\").addEventListener(\"click\", fit);\n  window.addEventListener(\"resize\", layout);\n\n  /* drag to pan */\n  var drag = null;\n  viewport.addEventListener(\"pointerdown\", function(e){\n    if(e.target.closest(\"a, button\")){ return; }\n    drag = {x:e.clientX, y:e.clientY, sl:viewport.scrollLeft, st:viewport.scrollTop};\n    viewport.classList.add(\"st-grabbing\");\n  });\n  window.addEventListener(\"pointermove\", function(e){\n    if(!drag){ return; }\n    viewport.scrollLeft = drag.sl - (e.clientX - drag.x);\n    viewport.scrollTop = drag.st - (e.clientY - drag.y);\n  });\n  window.addEventListener(\"pointerup\", function(){\n    drag = null;\n    viewport.classList.remove(\"st-grabbing\");\n  });\n\n  render();\n})();\n</script>"
    }
  ]
